/com,*********** Define Force Without Surface Effect Elements "Force" ***********
local,12,0,0.,0.,0.,0.,0.,0.
csys,0
CMBLOCK,_CM56_1 ,ELEM,        2
(8i10)
       933     -1262
/com,*********** Create Bearing Load ***********
et,4,154
MAT,4 $ TYPE,4 $ REAL,4 $ SECNUM,4 $ ESYS,0
eblock,11,COMPACT,,10
(11i9)
     5269     2726     2728     2727     2725     3192     9351     3020     9348
     5270     2728     2730     2729     2727     3191     9354     3019     9351
